{
  "version": 2,
  "installCommand": "cd .. && bun install && cd server",
  "buildCommand": "bunx prisma generate && bun run build",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}