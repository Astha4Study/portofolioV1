{
  "version": 2,
  "buildCommand": "cd server && prisma generate && cd .. && bun run build:server",
  "installCommand": "bun install",
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
